{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run dev:*)",
      "Bash(npm run:*)",
      "Bash(npx next:*)",
      "Bash(pkill -f \"next build\")",
      "Bash(pkill -f \"next dev\")",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(find . -type f -name .env*)",
      "Bash(git diff:*)",
      "Bash(npm audit:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(grep -E '^[a-z0-9-]+$')"
    ]
  }
}
