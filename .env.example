# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and should NEVER be committed to GitHub.

# Brevo (formerly Sendinblue) — email newsletter
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-api-key-here

# The numeric ID of the Brevo contact list subscribers go into
# Find it at: https://app.brevo.com/contact/list
BREVO_LIST_ID=2

# Sender details used for RSS campaign emails (configured in Brevo UI)
BREVO_SENDER_NAME=Sarita Das
BREVO_SENDER_EMAIL=your-email@example.com
